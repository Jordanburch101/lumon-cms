{
  "name": "lumon-payload",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "migrate": "bun -e \"process.argv=['bun','payload','migrate'];const{bin}=await import('./node_modules/payload/dist/bin/index.js');await bin()\"",
    "migrate:create": "bun -e \"process.argv=['bun','payload','migrate:create'];const{bin}=await import('./node_modules/payload/dist/bin/index.js');await bin()\"",
    "migrate:fresh": "bun -e \"process.argv=['bun','payload','migrate:fresh'];const{bin}=await import('./node_modules/payload/dist/bin/index.js');await bin()\"",
    "generate:types": "bun -e \"process.argv=['bun','payload','generate:types'];const{bin}=await import('./node_modules/payload/dist/bin/index.js');await bin()\"",
    "generate:importmap": "bun scripts/gen-importmap.ts",
    "generate:field-map": "bun scripts/generate-field-map.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "storybook": "bun .storybook/generate.ts && storybook dev -p 6006",
    "storybook:build": "bun .storybook/generate.ts && storybook build",
    "db:pull": "bun --env-file=.env scripts/db-sync.ts pull",
    "db:push": "bun --env-file=.env scripts/db-sync.ts push"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1006.0",
    "@base-ui/react": "^1.2.0",
    "@hugeicons/core-free-icons": "^3.3.0",
    "@hugeicons/react": "^1.1.5",
    "@payloadcms/db-sqlite": "^3.79.0",
    "@payloadcms/next": "^3.79.0",
    "@payloadcms/plugin-mcp": "^3.79.0",
    "@payloadcms/plugin-seo": "3.79.0",
    "@payloadcms/richtext-lexical": "^3.79.0",
    "@payloadcms/storage-s3": "^3.79.0",
    "@tailwindcss/typography": "^0.5.19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "graphql": "^16.13.1",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.577.0",
    "maplibre-gl": "^5.19.0",
    "motion": "^12.35.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "payload": "^3.79.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.3",
    "react-resizable-panels": "^4.7.1",
    "recharts": "2.15.4",
    "shadcn": "^3.8.5",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.0",
    "@github-ui/storybook-addon-performance-panel": "^1.1.4",
    "@storybook/addon-a11y": "^10.2.19",
    "@storybook/addon-docs": "^10.2.19",
    "@storybook/addon-themes": "^10.2.19",
    "@storybook/nextjs": "^10.2.19",
    "@tailwindcss/postcss": "^4",
    "@types/bun": "^1.3.10",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "storybook": "^10.2.19",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "ultracite": "7.2.4"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
