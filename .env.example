# Payload
PAYLOAD_SECRET=replace-with-random-string

# Database (libsql)
# Local file: file:./payload.db
# Remote libsql: libsql://your-service.railway.app or http://libsql.railway.internal:8080
DATABASE_URI=file:./payload.db
DATABASE_AUTH_TOKEN=

# Server URL (required in production for media processing hooks)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# S3 Storage (Railway bucket)
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=

# Better Auth
BETTER_AUTH_SECRET=   # Generate with: openssl rand -base64 32

# Auto-login (dev only — skips admin login screen)
AUTOLOGIN_EMAIL=
